# Hey there! Here's the .env file, used to store secrets and some simple config!
# You can configure the MySQL here, as well as toggling the whitelist

# The base URL that is accessible to the internet, primarily used to link to things as images in the redirector, as they require absolute URLs.
# Make sure it does not end with a slash. Example: HOST = "https://link.example.com"
HOST = "http://localhost:9404"

# On what localhost address this shall be available. This is important for eventually opening it to the public
PORT = 9404

# If set to "true", only pre-approved users can log in and sign up.
# You can manage this in whitelist.js
WHITELIST = "true"

# Port for MySQL database
MYSQL_PORT = 3306
# Host (e.g. "localhost")
MYSQL_HOST = "localhost"
# Username
MYSQL_USER = ""
# Password
MYSQL_PASSWORD = ""
# You can leave the database as-is, but you can change it if you want to. Do not leave it empty though!
MYSQL_DATABASE = "sitecite"

# Secret for generating coookies with integrity
# It can be anything really, but I'd recommend a long cryptographically generated string of 32 characters or more.
COOKIE_SECRET = "<MAKE ME UNIQUE!>"

# Toggle whether or not users can sign up with a username and password.
# If this is set to false, a proper alternative needs to be provided, such as OAuth with Discord (otherwise it is impossible to sign up)
# options: "true" | anything else for false
USERNAME_ACCOUNTS = "true"

# Configure Discord OAuth2
# It's optional, as long as a user has an alternative. In selfhosted, private use settings, I'd recommend against OAuth.

# Your application ID
DISCORD_ID = ""
# Your client's secret
DISCORD_SECRET = ""
# The redirect URL set in Discord. It should be something like: /account/discord
DISCORD_URL = ""
# The URL to redirect users to in order to authenticate
DISCORD_AUTH_URL = ""

# key for abuse.ch
ABUSE_CH_KEY = ""
